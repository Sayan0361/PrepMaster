@model IEnumerable<PrepMaster.Models.TestModel>

@{
    ViewBag.Title = "Index";
}

@Html.Partial("_Navbar")
@Html.Partial("_UnauthorizedAccess")

<style>
    .custom-table {
        border-collapse: separate;
        border-spacing: 0;
        /* border: 1px solid #ccc; */
        border-radius: 10px;
        overflow: hidden;
    }
</style>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<main class="container mt-5 pt-5 w-100" id="main-container">
    <div class="text-lg-start">

        <h1>Assessment PlayGround</h1>

        <div class="d-flex flex-row gap-2">
            <small>
                Grade: <strong>10</strong>
            </small>
            <small>
                Student ID: <strong>#1234</strong>
            </small>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4 mt-3">
            <li class="nav-item">
                <button class="nav-link active"
                        data-bs-toggle="tab"
                        data-bs-target="#available"
                        type="button">
                    Available Tests
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                        data-bs-toggle="tab"
                        data-bs-target="#results"
                        type="button">
                    My Results
                </button>
            </li>
        </ul>

        <!-- Tab Content -->
        <div class="tab-content row">

            <!-- Available Tests -->
            <div class="tab-pane fade show active" id="available">

                @if (Model != null && Model.Any())
                {
                    <div class="row g-4">
                        @foreach (var test in Model)
                        {
                            <div class="col-12 col-md-6 col-lg-3">
                                @Html.Partial("_Card", test)
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center mt-5">
                        <div class="card shadow-sm p-4">
                            <h5 class="text-muted mb-2">No Tests Available</h5>
                            <p class="text-secondary mb-0">
                                There are currently no tests assigned to you.
                            </p>
                        </div>
                    </div>
                }

            </div>

            <!-- Results -->
            <div class="tab-pane fade" id="results">
                <div class="p-4">
                    <h1 class="text-primary">Here is Your Performance <i class="bi bi-bar-chart-line"></i> </h1>
                </div>

                <div class="container p-3 pb-5">
                    <!-- 'row-cols-*' defines cards per row, 'g-4' adds gutter spacing -->
                    <div class="row row-cols-1 row-cols-md-3 g-4">
                        <div class="col">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <i class="bi bi-bullseye fs-1 text-primary me-3 "></i>
                                    <div>
                                        <h5 class="card-title mb-1">OVERALL AVERAGE</h5>
                                        <p class="card-text mb-0">Content.</p>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <!-- Add more .col cards here -->
                        <div class="col">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <i class="bi bi-check2-circle fs-1 text-success me-3"></i>
                                    <div>
                                        <h5 class="card-title mb-1">TESTS PASSED</h5>
                                        <p class="card-text mb-0">Content.</p>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <i class="bi bi-trophy fs-1 text-warning me-3"></i>
                                    <div>
                                        <h5 class="card-title mb-1">TOP SUBJECT</h5>
                                        <p class="card-text mb-0">Content.</p>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <table class="table table-light pt-3 custom-table" border="0.5">
                    <thead>
                        <tr><th colspan="4" scope="col">Assesment list</th></tr>
                        <tr>
                            <th scope="col">Date Taken</th>
                            <th scope="col">Subject</th>
                            <th scope="col">Assessment Title</th>
                            <th scope="col">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <th scope="row">1</th>
                            <td>Mark</td>
                            <td>Otto</td>
                            <td>mdo</td>
                        </tr>
                        <tr>
                            <th scope="row">2</th>
                            <td>Jacob</td>
                            <td>Thornton</td>
                            <td>fat</td>
                        </tr>
                        <tr>
                            <th scope="row">3</th>
                            <td>Larry</td>
                            <td>the Bird</td>
                            <td>twitter</td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</main>

<script>
    $(document).ready(function () {

        const studentID = localStorage.getItem("UserID")

        // Access verification
        verifyUserAccess({
            verifyUrl: '@Url.Action("VerifyUser", "Auth")',
            redirectUrl: '@Url.Action("Index", "Home")',
            hideSelector: "#main-container"
        });

        // Duration & Due Time Calculation
        $(".test-card").each(function () {

            var card = $(this);

            var startTime = card.data("start");
            var endTime = card.data("end");

            var start = new Date(startTime);
            var end = new Date(endTime);

            // Duration
            var diffMs = end - start;
            var diffMinutes = Math.floor(diffMs / 60000);
            var hours = Math.floor(diffMinutes / 60);
            var minutes = diffMinutes % 60;

            var duration = hours + " hr " + minutes + " min";
            card.find(".durationText").text(duration);

            // Due Time
            var today = new Date();
            today.setHours(0, 0, 0, 0);

            var startDate = new Date(startTime);
            startDate.setHours(0, 0, 0, 0);

            var diffDays = Math.ceil((startDate - today) / (1000 * 60 * 60 * 24));

            var dueText = "";

            if (diffDays > 0)
                dueText = diffDays + " days left";
            else if (diffDays === 0)
                dueText = "Today";
            else
                dueText = "Expired";

            card.find(".dueText").text(dueText);

            //Disable the button for expired test

            var now = new Date();
            const ediff = end - now;
            const sdiff = start - now;

            if (ediff < 0 || sdiff > 0) {
                $(this).find('.startTestBtn').prop('disabled', true);
            }

        });

        $(document).on("click", ".startTestBtn", function () {
            Swal.fire({
                title: "Are you sure?",
                text: "Would you like to start the test?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
            }).then((result) => {
                if (result.isConfirmed) {
                    var card = $(this).closest(".test-card");

                    var testId = card.data("id");

                    // Save to localStorage
                    //localStorage.setItem("selectedTestId", testId);

                    sessionStorage.setItem("selectedTestId", testId);

                    console.log("Saved TestID:", testId);

                    // Optional: redirect to test page
                    // window.location.href = "/Student/StartTest";

                    window.location.href = '@Url.Action("StartTest", "Test")';
                }
            });

        });

    });
</script>