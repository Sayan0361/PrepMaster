@model IEnumerable<PrepMaster.Models.TestModel>

@{
    ViewBag.Title = "Index";
}

@{
    var totalObtained = Model
                .Where(r => r.AttemptStatus == "Attempted")
                ?.Sum(r => r.ScoreObtained) ?? 0;

    var totalFull = Model
                .Where(r => r.AttemptStatus == "Attempted")
                ?.Sum(r => r.TotalMarks) ?? 0;

    var averagePercentage = Math.Floor(totalFull > 0 ? (totalObtained * 100.0 / totalFull) : 0);

    var highestMarkSub = Model
                .Where(r => r.AttemptStatus == "Attempted")
                ?.OrderByDescending(r => r.ScoreObtained)
                ?.FirstOrDefault()
                ?.SubjectName ?? "------";

    var testPassed = Model.Where(r => r.ResultStatus == "Pass").Count();
}

@Html.Partial("_Navbar")
@Html.Partial("_UnauthorizedAccess")

<style>
    .custom-table {
        border-collapse: separate;
        border-spacing: 0;
        /* border: 1px solid #ccc; */
        border-radius: 10px;
        overflow: hidden;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .status-active {
        background-color: #e1f7ed;
        color: #20794d;
        padding: 4px;
        border: none;
        border-radius: 15%;
    }

    .status-closed {
        background-color: antiquewhite;
        color: red;
        padding: 4px;
        border: none;
        border-radius: 15%;
    }
</style>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<main class="container  w-100" id="main-container">

    <div class="modal fade" id="examInstructionsModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">Exam Instructions & Security Rules</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h5 class="text-success border-bottom pb-2">Do's</h5>
                            <ul class="list-group list-group-flush mt-3">
                                <li class="list-group-item px-0">Ensure a stable internet connection.</li>
                                <li class="list-group-item px-0">Keep focus exclusively on the exam screen.</li>
                                <li class="list-group-item px-0">Submit the test manually before the timer ends.</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h5 class="text-danger border-bottom pb-2">Don'ts</h5>
                            <ul class="list-group list-group-flush mt-3">
                                <li class="list-group-item px-0"><strong>Do not</strong> exit Fullscreen mode.</li>
                                <li class="list-group-item px-0"><strong>Do not</strong> switch tabs or open apps.</li>
                                <li class="list-group-item px-0"><strong>Do not</strong> refresh or use the back button.</li>
                            </ul>
                        </div>
                    </div>
                    <div class="alert alert-warning mt-4 mb-4">
                        <strong>Warning:</strong> Exiting fullscreen, switching tabs, or losing window focus 3 times will result in immediate automatic submission.
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input border-secondary" type="checkbox" id="agreeCheckboxIndex" style="cursor: pointer;">
                        <label class="form-check-label fw-bold" for="agreeCheckboxIndex" style="cursor: pointer;">
                            I have read and understood the instructions. I am ready to begin.
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="confirmStartExamBtn" disabled>Proceed to Exam</button>
                </div>
            </div>
        </div>
    </div>



    <div class="text-lg-start tab-title-container">

        <div class="tab-title">
            <h1 class="text-primary activeTitle">
                Assessment Playground
                <i class="bi bi-clipboard-check"></i>
            </h1>
        </div>

        <div class="d-flex flex-row gap-2">

            <small>
                Student ID: <strong id="studentID-display"></strong>
            </small>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4 mt-3">
            <li class="nav-item">
                <button class="nav-link active"
                        data-bs-toggle="tab"
                        data-bs-target="#available"
                        type="button">
                    Available Tests
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                        data-bs-toggle="tab"
                        data-bs-target="#results"
                        type="button">
                    My Results
                </button>
            </li>
        </ul>

        <!-- Tab Content -->
        <div class="tab-content row">

            <!-- Available Tests -->
            <div class="tab-pane fade show active" id="available">

                @if (Model != null && Model.Any())
                {
                    <div class="row g-4">
                        @foreach (var test in Model)
                        {
                            <div class="col-12 col-md-6 col-lg-3">
                                @Html.Partial("_Card", test)
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center mt-5">
                        <div class="card shadow-sm p-4">
                            <h5 class="text-muted mb-2">No Tests Available</h5>
                            <p class="text-secondary mb-0">
                                There are currently no tests assigned to you.
                            </p>
                        </div>
                    </div>
                }

            </div>

            <!-- Results -->
            <div class="tab-pane fade" id="results">


                <div class="container p-3 pb-5">
                    <!-- 'row-cols-*' defines cards per row, 'g-4' adds gutter spacing -->
                    <div class="row row-cols-1 row-cols-md-3 g-4">
                        <div class="col">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <i class="bi bi-bullseye fs-1 text-primary me-3 "></i>
                                    <div>
                                        <h5 class="card-title mb-1">AVERAGE PERCENTAGE</h5>
                                        <p class="card-text mb-0" id="averageTextDisplay">@averagePercentage</p>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <!-- Add more .col cards here -->
                        <div class="col">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <i class="bi bi-check2-circle fs-1 text-success me-3"></i>
                                    <div>
                                        <h5 class="card-title mb-1">TESTS PASSED</h5>
                                        <p class="card-text mb-0">@testPassed</p>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card h-100">
                                <div class="card-body d-flex align-items-center">
                                    <i class="bi bi-trophy fs-1 text-warning me-3"></i>
                                    <div>
                                        <h5 class="card-title mb-1">TOP SUBJECT</h5>
                                        <p class="card-text mb-0">@highestMarkSub</p>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <table class="table table-light pt-3 custom-table">
                    <thead>
                        <tr><th colspan="6" scope="col">Assesment list</th></tr>
                        <tr>
                            <th scope="col">Date Taken</th>
                            <th scope="col">Subject</th>
                            <th scope="col">Assessment Title</th>
                            <th scope="col">Score</th>
                            <th scope="col">Out of</th>
                            <th scope="col">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var res in Model)
                        {
                            if (res.AttemptStatus == "Attempted")
                            {
                                <tr>
                                    <td scope="row">@res.StartDateTime</td>
                                    <td>@res.SubjectName</td>
                                    <td>@res.Title</td>
                                    <td>@res.ScoreObtained</td>
                                    <td>@res.TotalMarks</td>
                                    <td class="result-status">
                                        <span class="status-badge  status" id="test-status">@res.ResultStatus</span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</main>

<script>

    function startExam() {
        if (document.documentElement.requestFullscreen) {
            document.documentElement.requestFullscreen();
        }
    }

    function renderTitle() {
        const activeTab = $(this).data("bs-target")
        const title = activeTab === "#available"
            ? "Assessment Playground"
            : "Performance";

        const icon = activeTab === "#available"
            ? "bi-clipboard-check"
            : "bi-bar-chart-line";

        const html = `
            <h1 class="text-primary activeTitle">
                ${title} <i class="bi ${icon}"></i>
            </h1>
        `;

        $(".tab-title").empty();
        $(".tab-title").append(html);
    }

    function renderStatusBadge() {
        $(".status").each(function () {
            const status = $(this).text().trim()
            console.log(status);
            $(this).removeClass("status")
            if (status == 'Pass') {
                $(this).addClass('status-active');
            }
            else{
                $(this).addClass('status-closed');
            }
        })
    }

    $(document).ready(function () {

        const studentID = localStorage.getItem("UserID")

        // Access verification
        verifyUserAccess({
            verifyUrl: '@Url.Action("VerifyUser", "Auth")',
            redirectUrl: '@Url.Action("Index", "Home")',
            hideSelector: "#main-container"
        });

        $("#studentID-display").text("#" + studentID);

        $(".nav-link ").click(renderTitle)

        // Duration & Due Time Calculation
        $(".test-card").each(function () {

            var card = $(this);

            var startTime = card.data("start");
            var endTime = card.data("end");

            var start = new Date(startTime);
            var end = new Date(endTime);

            // Duration
            var diffMs = end - start;
            var diffMinutes = Math.floor(diffMs / 60000);
            var hours = Math.floor(diffMinutes / 60);
            var minutes = diffMinutes % 60;

            var duration = hours + " hr " + minutes + " min";
            card.find(".durationText").text(duration);

            // Due Time
            var today = new Date();
            today.setHours(0, 0, 0, 0);

            var startDate = new Date(startTime);
            startDate.setHours(0, 0, 0, 0);

            var diffDays = Math.ceil((startDate - today) / (1000 * 60 * 60 * 24));

            var dueText = "";

            if (diffDays > 0)
                dueText = diffDays + " days left";
            else if (diffDays === 0)
                dueText = "Today";
            else
                dueText = "Expired";

            card.find(".dueText").text(dueText);

            //Disable the button for expired test

            var now = new Date();
            const ediff = end - now;
            const sdiff = start - now;


            if (ediff < 0 || sdiff > 0) {
                $(this).find('.startTestBtn').prop('disabled', true);
            }

        });

        renderStatusBadge()

        $(document).on("click", ".startTestBtn", function () {
            var card = $(this).closest(".test-card");
            var testId = card.data("id");

            Swal.fire({
                title: 'Exam Instructions & Security Rules',
                html: `
                    <div class="text-start mt-3">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <h6 class="text-success border-bottom pb-2">Do's</h6>
                                <ul class="small ps-3 mb-0">
                                    <li class="mb-1">Ensure a stable internet connection.</li>
                                    <li class="mb-1">Keep focus exclusively on the exam screen.</li>
                                    <li>Submit the test manually before the timer ends.</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-danger border-bottom pb-2">Don'ts</h6>
                                <ul class="small ps-3 mb-0">
                                    <li class="mb-1"><strong>Do not</strong> exit Fullscreen mode.</li>
                                    <li class="mb-1"><strong>Do not</strong> switch tabs or open apps.</li>
                                    <li><strong>Do not</strong> refresh or use the back button.</li>
                                </ul>
                            </div>
                        </div>
                        <div class="alert alert-warning small mt-4 mb-3 p-2">
                            <strong>Warning:</strong> Exiting fullscreen, switching tabs, or losing window focus 2 times will result in immediate automatic submission.
                        </div>
                        <div class="form-check mt-2">
                            <input class="form-check-input border-secondary" type="checkbox" id="agreeCheckboxSwal" style="cursor: pointer;">
                            <label class="form-check-label fw-bold small" for="agreeCheckboxSwal" style="cursor: pointer;">
                                I have read and understood the instructions. I am ready to begin.
                            </label>
                        </div>
                    </div>
                `,
                width: '700px',
                showCancelButton: true,
                confirmButtonText: 'Proceed to Exam',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#6c757d',
                allowOutsideClick: false,
                didOpen: () => {
                    const confirmBtn = Swal.getConfirmButton();
                    confirmBtn.disabled = true;

                    $('#agreeCheckboxSwal').change(function() {
                        confirmBtn.disabled = !this.checked;
                    });
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    sessionStorage.setItem("selectedTestId", testId);
                    localStorage.setItem("StartTest", true);

                    window.location.href = '@Url.Action("StartTest", "Test")';
                }
            });
        });

    });
</script>