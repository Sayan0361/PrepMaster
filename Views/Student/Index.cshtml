@model IEnumerable<PrepMaster.Models.TestModel>

@{
    ViewBag.Title = "Index";
}

@Html.Partial("_Navbar")

<main class="container mt-5 pt-5 w-100">
    <div class="text-lg-start">

        <h1>Assessment PlayGround</h1>

        <div class="d-flex flex-row gap-2">
            <small>
                Grade: <strong>10</strong>
            </small>
            <small>
                Student ID: <strong>#1234</strong>
            </small>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4 mt-3" id="assessmentTabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link active"
                        data-bs-toggle="tab"
                        data-bs-target="#available"
                        type="button">
                    Available Tests
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                        data-bs-toggle="tab"
                        data-bs-target="#results"
                        type="button">
                    My Results
                </button>
            </li>
        </ul>

        <!-- Tab Content -->
        <div class="tab-content">

            <!-- Available Tests Tab -->
            <div class="tab-pane fade show active" id="available">

                @if (Model != null && Model.Any())
                {
                    foreach (var test in Model)
                    {
                        @Html.Partial("_Card", test)
                    }
                }
                else
                {
                    <div class="text-center mt-5">
                        <div class="card shadow-sm p-4">
                            <h5 class="text-muted mb-2">No Tests Available</h5>
                            <p class="text-secondary mb-0">
                                There are currently no tests assigned to you.
                                Please check back later.
                            </p>
                        </div>
                    </div>
                }

            </div>

            <!-- Results Tab -->
            <div class="tab-pane fade" id="results">
                <div class="text-center mt-5">
                    <div class="card shadow-sm p-4">
                        <h5 class="text-muted">No Results Available</h5>
                        <p class="text-secondary mb-0">
                            You haven't attempted any tests yet.
                        </p>
                    </div>
                </div>
            </div>

        </div>

    </div>
</main>

