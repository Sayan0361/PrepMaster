
@{
    ViewBag.Title = "Analytics";
}

@Html.Partial("_Navbar")

@*Page Header*@

<div class="d-flex justify-content-between align-items-end mb-5">
    <div>
        <h1 class="fw-bold">Test Analysis</h1>
        <p>Prof. Stark Dashboard</p>
    </div>
    <div>
        <button class="btn btn-primary">+ Create New Test</button>
    </div>
</div>

@*Filter Section*@

<div class="d-flex flex-column flex-md-row align-items-md-end gap-3 shadow p-4">

    <div class="w-100 w-md-33">
        <label class="form-label">
            <i class="fa fa-solid fa-filter">
            </i>
            Filter By Class
        </label>
        <select class="form-select w-100 fw-bold">
            <option>Choose Class</option>
            <option>Grade 9</option>
            <option>Grade 10</option>
        </select>
    </div>

    <div class="w-100 w-md-33">
        <label class="form-label">
            <i class="fa-solid fa-file-lines"></i>
            Select Assessment Test
        </label>
        <select class="form-select w-100 fw-bold">
            <option>Select Assessment</option>
            <option>SQL Test</option>
            <option>Maths Test</option>
        </select>
    </div>

</div>

@* Analytics + Results Section *@

<div class="row mt-4 g-4">

    <!-- LEFT PORTION -->
    <div class="col-lg-4">

        <!-- Stats -->
        <div class="row g-3 mb-3">

            <div class="col-6">
                <div class="p-3 shadow rounded text-center">
                    <p class="text-muted small mb-1">TEST AVERAGE</p>
                    <h2 class="fw-bold text-primary">79%</h2>
                </div>
            </div>

            <div class="col-6">
                <div class="p-3 shadow rounded text-center">
                    <p class="text-muted small mb-1">TOTAL SUBMISSIONS</p>
                    <h2 class="fw-bold">4</h2>
                </div>
            </div>

        </div>

        <!-- Score Distribution -->
        <div class="p-4 shadow rounded text-center">
            <h5 class="fw-bold mb-3">Score Distribution</h5>
            <p class="text-muted small">Rendered via HTML5 Canvas</p>

            <!-- Chart Placeholder -->
            <div style="height:250px">
                <canvas id="scoreChart"></canvas>
            </div>

        </div>

    </div>


    <!-- RIGHT PORTION -->
    <div class="col-lg-8">

        <div class="shadow rounded p-4">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0">Student Results List</h4>
                <span class="badge bg-primary-subtle text-primary">
                    Grade 9: Basic Algebra Quiz
                </span>
            </div>

            <table class="table align-middle">

                <thead class="text-muted small">
                    <tr>
                        <th>STUDENT</th>
                        <th>SUBMITTED AT</th>
                        <th>SCORE</th>
                        <th>STATUS</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>
                            <strong>Tom Holland</strong><br>
                            <small class="text-muted">#9911</small>
                        </td>
                        <td>09:15 AM</td>
                        <td class="fw-bold">82%</td>
                        <td><span class="badge bg-success-subtle text-success">PASS</span></td>
                    </tr>

                    <tr>
                        <td>
                            <strong>Zendaya</strong><br>
                            <small class="text-muted">#9912</small>
                        </td>
                        <td>09:20 AM</td>
                        <td class="fw-bold">98%</td>
                        <td><span class="badge bg-success-subtle text-success">PASS</span></td>
                    </tr>

                    <tr>
                        <td>
                            <strong>Jacob Batalon</strong><br>
                            <small class="text-muted">#9913</small>
                        </td>
                        <td>09:25 AM</td>
                        <td class="fw-bold text-danger">58%</td>
                        <td><span class="badge bg-danger-subtle text-danger">FAIL</span></td>
                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>


<script>
    $(document).ready(function () {

        const teacherID = localStorage.getItem("UserID")

        $.ajax({
            url: '@Url.Action("AnalyticsData", "Teacher")',
            type: 'GET',
            data: {
                TeacherId: parseInt(teacherID)
            },
            success: function (response) {
                console.log("S-Response: ", response)
            },
            error: function (response) {
                console.log("E-Response: ", response)
            }
        })
    })
</script>