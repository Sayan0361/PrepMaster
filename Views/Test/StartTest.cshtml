@{
    ViewBag.Title = "Exam";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .cursor-pointer {
        cursor: pointer !important;
    }

    /* Proctoring Webcam Box Styles */
    #proctorBox {
        position: fixed;
        bottom: 20px;
        right: 20px;
        width: 220px;
        height: 165px;
        border: 3px solid #0d6efd;
        border-radius: 8px;
        overflow: hidden;
        background: #000;
        z-index: 1050;
        display: none; /* Initially hidden, shows when exam starts */
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }

    #webcam {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transform: scaleX(-1); /* Mirror effect for natural feeling */
    }

    #proctorStatus {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        background: rgba(0, 0, 0, 0.7);
        color: #fff;
        text-align: center;
        font-size: 13px;
        padding: 4px 0;
        font-weight: 600;
    }
</style>

@*@Html.Partial("_UnauthorizedAccess")*@

<div id="fullscreenPrompt" class="text-center p-5">
    <h4>Exam Security</h4>
    <p>This exam must run in fullscreen mode. Please don't open any tab or Menu.</p>
    <p id="cameraStatus" class="text-warning fw-bold">Requesting camera access and loading proctoring models...</p>

    <!-- Disabled initially until camera and models are ready -->
    <button class="btn btn-primary" id="enterFullscreen" disabled>
        Enter Fullscreen & Start Exam
    </button>
</div>

<div class="container-fluid bg-light min-vh-100 py-3" id="examContainer" style="display: none;">
    <div class="container mb-3">
        <div class="alert border-start border-3 border-primary shadow-sm d-flex justify-content-between align-items-center flex-wrap py-2 px-3 small mb-0">
            <div>
                <strong>Exam Mode:</strong>
                <span class="text-primary">Timer running. Answers are auto-saved locally.</span>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="card shadow border-0 rounded-3">
            <div class="bg-dark text-white p-3 p-md-4">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <span class="badge bg-primary px-2 py-1 mb-2 small" id="test-subject"></span>
                        <h5 class="fw-bold mb-0" id="test-title"></h5>
                        <p class="text-secondary small mb-0" id="test-description"></p>
                    </div>

                    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                        <div class="d-inline-block bg-black rounded-3 px-3 py-2 text-center">
                            <div class="text-secondary text-uppercase small" id="timeRemainingHeader">
                                Time Remaining
                            </div>
                            <div class="text-warning fw-bold fs-5" id="timerDisplay"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-body p-3 p-md-4" id="question-container">
            </div>

            <div class="card-footer bg-white py-3 px-3 px-md-4 text-end">
                <button class="btn btn-success btn-sm px-4" id="submitBtn">
                    Submit Exam
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Floating Proctoring Box -->
<div id="proctorBox">
    <video id="webcam" autoplay muted playsinline></video>
    <div id="proctorStatus">Initializing...</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.js" xintegrity="sha512-+k1pnlgt4F1H8L7t3z95o3/KO+o78INEcXTbnoJQ/F2VqDVhWoaiVml/OEHv9HsVgxUaVW+IbiZPUJQfF/YxZw==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<!-- Face API Script -->
<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>

<script>
    // --- FACE API PROCTORING LOGIC ---
    let faceMissingTime = 0;
    const MAX_MISSING_TIME = 5; // Auto submit if face is missing for 10 seconds
    let isSubmitting = false;

    async function initProctoring() {
        const statusEl = $("#cameraStatus");
        const videoEl = document.getElementById('webcam');

        try {
            // 1. Request Camera Access FIRST
            // This ensures the browser prompt appears immediately and the camera turns on.
            statusEl.text("Requesting camera access...").addClass("text-warning");

            const stream = await navigator.mediaDevices.getUserMedia({
                video: { width: 640, height: 480 },
                audio: false
            });

            videoEl.srcObject = stream;

            // Wait for video to be ready and start playing
            await new Promise((resolve) => {
                videoEl.onloadedmetadata = () => {
                    videoEl.play();
                    resolve();
                };
            });

            statusEl.text("Camera active. Loading security models...").removeClass("text-warning").addClass("text-primary");

            // 2. Load Models while the camera is already visible to the user
            const MODEL_URL = 'https://cdn.jsdelivr.net/gh/justadudewhohacks/face-api.js@master/weights';
            await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
            // 3. Update UI to allow exam entry
            statusEl.text("Security Check Passed. Ready to begin.").removeClass("text-primary").addClass("text-success");
            $("#enterFullscreen").prop("disabled", false);

            // 4. Start Detection Loop
            startDetectionLoop(videoEl);

        } catch (error) {
            console.error("Proctoring Error:", error);

            if (error.name === "NotAllowedError" || error.name === "PermissionDeniedError") {
                statusEl.html("<span class='text-danger'>Camera permission was denied. Please click the camera icon in your address bar to reset permissions and refresh.</span>");
            } else if (error.name === "NotFoundError" || error.name === "DevicesNotFoundError") {
                statusEl.html("<span class='text-danger'>No webcam detected. Please connect a camera and refresh.</span>");
            } else {
                statusEl.html("<span class='text-danger'>Setup Error: " + error.message + "</span>");
            }
        }
    }

    function startDetectionLoop(videoEl) {
        setInterval(async () => {
            // Only run detection if the exam container is visible and not already submitting
            if ($("#examContainer").is(":hidden") || isSubmitting) return;

            const detections = await faceapi.detectAllFaces(videoEl, new faceapi.TinyFaceDetectorOptions());

            const proctorStatus = $("#proctorStatus");
            const proctorBox = $("#proctorBox");

            if (detections.length === 0) {
                faceMissingTime++;
                proctorStatus.text(`Face Missing! (${faceMissingTime}s)`).css("color", "#ff4d4d");
                proctorBox.css("border-color", "#ff4d4d");

                if (faceMissingTime >= MAX_MISSING_TIME && !isSubmitting) {
                    isSubmitting = true;
                    $("#proctorStatus").text("Auto Submitting...");

                    Swal.fire({
                        title: "Proctoring Alert",
                        text: "Face not detected in the camera for too long. Your test will be automatically submitted.",
                        icon: "error",
                        allowOutsideClick: false,
                        showCancelButton: false,
                        confirmButtonText: 'Submit Now',
                        confirmButtonColor: "#d33",
                    }).then(() => {
                        const testID = sessionStorage.getItem("selectedTestId");
                        const userID = localStorage.getItem("UserID");
                        submitTestData(testID, userID);
                    });
                }
            } else if (detections.length > 1) {
                faceMissingTime = 0;
                proctorStatus.text("Warning: Multiple Faces!").css("color", "#ffcc00");
                proctorBox.css("border-color", "#ffcc00");
                $("#proctorStatus").text("Auto Submitting...");

                Swal.fire({
                    title: "Proctoring Alert",
                    text: "Multiple face detected",
                    icon: "error",
                    allowOutsideClick: false,
                    showCancelButton: false,
                    confirmButtonText: 'Submit Now',
                    confirmButtonColor: "#d33",
                }).then(() => {
                    const testID = sessionStorage.getItem("selectedTestId");
                    const userID = localStorage.getItem("UserID");
                    submitTestData(testID, userID);
                });

            } else {
                faceMissingTime = 0;
                proctorStatus.text("Proctoring Active").css("color", "#99ff99");
                proctorBox.css("border-color", "#0d6efd");
            }
        }, 1000);
    }

    function renderQuestions(questions) {
        questions.map((q, ind) => {
            const questionHTML = `
                <div class="mb-4 questionCard">
                    <input type="hidden" value="${q.QuestionId}" class="questionID"/>
                    <h6 class="mb-3">
                        ${ind+1}. ${q.QuestionText}
                    </h6>
                    <div class="row g-3 optionDiv">
                        <div class="col-12 col-md-6">
                            <label class="card p-3 option-card">
                                <div class="d-flex align-items-center">
                                    <input class="form-check-input me-3" type="radio" name="q${ind}" value="A" />
                                    <span class="badge bg-light text-dark border me-3">A</span>
                                    <span>${q.OptionA}</span>
                                </div>
                            </label>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="card p-3 option-card">
                                <div class="d-flex align-items-center">
                                    <input class="form-check-input me-3" type="radio" name="q${ind}" value="B" />
                                    <span class="badge bg-light text-dark border me-3">B</span>
                                    <span>${q.OptionB}</span>
                                </div>
                            </label>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="card p-3 option-card">
                                <div class="d-flex align-items-center">
                                    <input class="form-check-input me-3" type="radio" name="q${ind}" value="C" />
                                    <span class="badge bg-light text-dark border me-3">C</span>
                                    <span>${q.OptionC}</span>
                                </div>
                            </label>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="card p-3 option-card">
                                <div class="d-flex align-items-center">
                                    <input class="form-check-input me-3" type="radio" name="q${ind}" value="D" />
                                    <span class="badge bg-light text-dark border me-3">D</span>
                                    <span>${q.OptionD}</span>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>
            `;
            $("#question-container").append(questionHTML)
        })
    }

    function formatTestTime(StartDateTime, EndDateTime) {
        const start = parseInt(StartDateTime.match(/\d+/)[0]);
        const end = parseInt(EndDateTime.match(/\d+/)[0]);
        const duration = (end - start) / 1000; // seconds
        return Math.floor(duration);
    }

    function renderTimer(totalSeconds, testID, userID) {
        var intervalID = setInterval(function () {
            const hours = Math.floor(totalSeconds / 3600);
            const minutes = Math.floor((totalSeconds % 3600) / 60);
            const seconds = totalSeconds % 60;

            const formatted =
                (hours > 0 ? (hours < 10 ? "0" : "") + hours + ":" : "") +
                (minutes < 10 ? "0" : "") + minutes + ":" +
                (seconds < 10 ? "0" : "") + seconds;

            $("#timerDisplay").text(formatted);
            totalSeconds--;

            if (totalSeconds < 0) {
                clearInterval(intervalID);
                $("#timerDisplay").text("Time Up!");

                if (!isSubmitting) {
                    isSubmitting = true;
                    Swal.fire({
                        title: "Auto Submit",
                        text: "Your test is auto submitted.",
                        icon: "success",
                        confirmButtonText: 'OK',
                        confirmButtonColor: "#3085d6",
                    })
                    .then(() => {
                        submitTestData(testID, userID);
                    });
                }
            }
        }, 1000);
    }

    function renderTestData(test) {
        $("#test-subject").text(test.SubjectName)
        $("#test-title").text(test.Title)
        $("#test-description").text(test.Description)
    }

    function submitTestData(testID, userID) {
        isSubmitting = true; // Prevent multiple submissions
        let answers = [];

        const refQuestionCard = $(".questionCard")
        refQuestionCard.each(function () {
            const questionID = $(this).find(".questionID").val();
            const refSelectedOption = $(this).find(".optionDiv").find("input:checked").val() || "";

            answers.push({
                QuestionId: parseInt(questionID),
                AttemptedOption: refSelectedOption
            })
        })

        $.ajax({
            url: '@Url.Action("SubmitTest", "Test")',
            type: 'POST',
            data: {
                TestID: testID,
                StudentId: userID,
                Answers: answers
            },
            success: function (response) {
                if (response.Success) {
                    Swal.fire({
                        title: "Success!!",
                        text: "Test Submitted Successfully",
                        icon: "success",
                        showCancelButton: false,
                        confirmButtonText: 'OK',
                        confirmButtonColor: "#3085d6",
                    }).then(() => {
                        var baseUrl = '@Url.Action("Index", "Student", new { id = 0 })';
                        window.location.href = baseUrl.replace("0", userID);
                    })
                }
            },
            error: function (response) {
                console.log("Error: ", response)
            }
        })
    }

    function redirectToDashboard(userID) {
        if (!userID || userID == "null" || userID === "undefined") {
            window.location.href = '/PrepMaster/Home/Index/';
        } else {
            window.location.href = '/PrepMaster/Student/Index/' + userID;
        }
    }

    $(document).ready(function () {
        // Init Face API Proctoring on Load
        initProctoring();

        const userID = localStorage.getItem("UserID");
        const testID = sessionStorage.getItem("selectedTestId");
        if (!userID || !testID ) {
            Swal.fire({
                icon: "error",
                title: "Imposter",
                text: "Unauthorized Access",
            }).then(() => {
                redirectToDashboard(userID);
            });
        }

        // Enter Full Screen & Show Exam
        $("#enterFullscreen").on("click", function () {
            if (document.documentElement.requestFullscreen) {
                document.documentElement.requestFullscreen()
                    .then(() => {
                        $("#fullscreenPrompt").hide();
                        $("#examContainer").show();
                        $("#proctorBox").fadeIn(); // Show webcam box
                    })
                    .catch(err => {
                        console.log("Fullscreen failed:", err);
                        alert("Fullscreen is required to take this exam.");
                    });
            }
        });

        // Detect Fullscreen Exit
        document.addEventListener("fullscreenchange", function () {
            if (!document.fullscreenElement && !isSubmitting) {
                $("#examContainer").hide();
                $("#proctorBox").hide();
                $("#fullscreenPrompt").show();

                isSubmitting = true;
                Swal.fire({
                    title: "Violation Detected",
                    text: "You exited fullscreen mode. Your test will be automatically submitted.",
                    icon: "error",
                    allowOutsideClick: false,
                    showCancelButton: false,
                    confirmButtonText: 'Submit Now',
                    confirmButtonColor: "#d33",
                }).then(() => {
                    submitTestData(testID, userID);
                    var baseUrl = '@Url.Action("Index", "Student", new { id = 0 })';
                    window.location.href = baseUrl.replace("0", userID);
                });
            }
        });

        // Stop page reloading
        $(document).keydown(function (e) {
            if (e.key === "F5" || (e.ctrlKey && e.key === "r")) {
                e.preventDefault();
                alert("Reloading the page is not allowed during the test.");
            }
        });

        // Disable back button
        history.pushState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };

        var tabSwitchCount = 0;
        // Malpractice Identification
        document.addEventListener("visibilitychange", function () {
            if (document.hidden && !isSubmitting) {
                tabSwitchCount++;
                if (tabSwitchCount >= 3) {
                    isSubmitting = true;
                    Swal.fire({
                        title: "Maximum malpractice violations reached. Your test has been automatically submitted.",
                        icon: "error"
                    }).then(() => {
                         submitTestData(testID, userID);
                         var baseUrl = '@Url.Action("Index", "Student", new { id = 0 })';
                         window.location.href = baseUrl.replace("0", userID);
                    });
                } else {
                    Swal.fire({
                        text: "Warning: Malpractice detected. This is violation " + tabSwitchCount + ". If you reach the maximum number of violations, your test will be automatically submitted.",
                        icon: "warning"
                    });
                }
            }
        });

        // AJAX call to fetch all questions
        $.ajax({
            url: '@Url.Action("StartTestJSONData", "Test")',
            type: 'GET',
            data: {
                TestID: testID,
                StudentId: userID
            },
            success: function (response) {
                if (response.Success) {
                    renderTestData(response.Test)
                    renderQuestions(response.Questions)

                    const totalSeconds = formatTestTime(response.Test.StartDateTime, response.Test.EndDateTime);

                    if (totalSeconds <= 7200) {
                        renderTimer(totalSeconds, testID, userID);
                    } else {
                        $("#timerDisplay").text("No Time Limit")
                        $("#timeRemainingHeader").addClass("d-none")
                    }
                }
                else {
                    Swal.fire({
                        title: "Error",
                        text: response.Message,
                        icon: "warning",
                        confirmButtonText: 'OK',
                        confirmButtonColor: "#3085d6",
                    })
                    .then(() => {
                        var baseUrl = '@Url.Action("Index", "Student", new { id = 0 })';
                        window.location.href = baseUrl.replace("0", userID);
                    })
                }
            },
            error: function (response) {
                console.log("Error response: ", response);
            }
        })

        // Submit Button Click Handler
        $("#submitBtn").on("click", function () {
            Swal.fire({
                title: "Are you sure?",
                text: "Would you like to submit the test?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: 'Yes',
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
            })
            .then((result) => {
                if (result.isConfirmed) {
                    const testID = sessionStorage.getItem("selectedTestId");
                    const userID = localStorage.getItem("UserID");
                    submitTestData(testID, userID);
                }
            })
        })

        document.addEventListener('contextmenu', function (e) {
            e.preventDefault();
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'F12' ||
                (e.ctrlKey && e.shiftKey && ['I', 'i', 'J', 'j', 'C', 'c'].includes(e.key)) ||
                (e.ctrlKey && ['U', 'u'].includes(e.key)) ||
                (e.metaKey && e.altKey && ['I', 'i', 'J', 'j', 'C', 'c'].includes(e.key)) ||
                (e.metaKey && ['U', 'u'].includes(e.key))) {
                e.preventDefault();
            }
        });

        window.addEventListener('blur', function () {
            if (isSubmitting) return;
            tabSwitchCount++;
            if (tabSwitchCount >= 1 && tabSwitchCount < 3) {
                 Swal.fire({
                    text: "Warning: Focus lost. Please do not open other applications or notifications. Violation " + tabSwitchCount + "/3.",
                    icon: "warning"
                });
            } else if (tabSwitchCount >= 3) {
                 isSubmitting = true;
                 Swal.fire({
                    title: "Violation Detected",
                    text: "You opened another application or menu too many times. Your test will be automatically submitted.",
                    icon: "error",
                    allowOutsideClick: false,
                    showCancelButton: false,
                    confirmButtonText: 'Submit Now',
                    confirmButtonColor: "#d33",
                }).then(() => {
                    const testID = sessionStorage.getItem("selectedTestId");
                    const userID = localStorage.getItem("UserID");
                    submitTestData(testID, userID);
                });
            }
        });
    });
</script>