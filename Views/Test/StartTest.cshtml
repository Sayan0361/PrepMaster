@{
    ViewBag.Title = "Exam";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<style>
    .cursor-pointer {
        cursor: pointer !important;
    }

</style>

@*@Html.Partial("_UnauthorizedAccess")*@


<div class="container-fluid bg-light min-vh-100 py-3">

    <!-- Top Banner -->
    <div class="container mb-3">
        <div class="alert border-start border-3 border-primary shadow-sm d-flex justify-content-between align-items-center flex-wrap py-2 px-3 small mb-0">
            <div>
                <strong>Exam Mode:</strong>
                <span class="text-primary">Timer running. Answers are auto-saved locally.</span>
            </div>
            @*<a class="text-danger text-decoration-none fw-semibold mt-1 mt-md-0 cursor-pointer" id="quitExam">
                Quit Exam
            </a>*@
        </div>
    </div>

    <!-- Exam Card -->
    <div class="container">
        <div class="card shadow border-0 rounded-3">

            <!-- Header -->
            <div class="bg-dark text-white p-3 p-md-4">
                <div class="row align-items-center">

                    <div class="col-lg-8">
                        <span class="badge bg-primary px-2 py-1 mb-2 small" id="test-subject">
                        </span>

                        <h5 class="fw-bold mb-0" id="test-title">
                        </h5>

                        <p class="text-secondary small mb-0" id="test-description">
                        </p>
                    </div>

                    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                        <div class="d-inline-block bg-black rounded-3 px-3 py-2 text-center">
                            <div class="text-secondary text-uppercase small" id="timeRemainingHeader">
                                Time Remaining
                            </div>
                            <div class="text-warning fw-bold fs-5" id="timerDisplay">
                                
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Questions Body -->
            <div class="card-body p-3 p-md-4" id="question-container">

                <!-- Question 1 -->



            </div>

            <!-- Submit Section -->
            <div class="card-footer bg-white py-3 px-3 px-md-4 text-end">
                <button class="btn btn-success btn-sm px-4" id="submitBtn">
                    Submit Exam
                </button>
            </div>

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.js" integrity="sha512-+k1pnlgt4F1H8L7t3z95o3/KO+o78INEcXTbnoJQ/F2VqDVhWoaiVml/OEHv9HsVgxUaVW+IbiZPUJQfF/YxZw==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

<script>

    function renderQuestions(questions) {


            questions.map((q, ind) => {
                const questionHTML = `
                    <div class="mb-4 questionCard">
                        <input type="hidden" value="${q.QuestionId}" class="questionID"/>
                        <h6 class="mb-3">
                            ${ind+1}. ${q.QuestionText}
                        </h6>
                        <div class="row g-3 optionDiv">

                            <!-- Option A -->
                            <div class="col-12 col-md-6">
                                <label class="card p-3 option-card">
                                    <div class="d-flex align-items-center">

                                        <input class="form-check-input me-3"
                                               type="radio"
                                               name="q${ind}"
                                               value="A" />

                                        <span class="badge bg-light text-dark border me-3">
                                            A
                                        </span>

                                        <span>${q.OptionA}</span>
                                    </div>
                                </label>
                            </div>

                            <!-- Option B -->
                            <div class="col-12 col-md-6">
                                <label class="card p-3 option-card">
                                    <div class="d-flex align-items-center">

                                        <input class="form-check-input me-3"
                                               type="radio"
                                               name="q${ind}"
                                               value="B" />

                                        <span class="badge bg-light text-dark border me-3">
                                            B
                                        </span>

                                        <span>${q.OptionB}</span>
                                    </div>
                                </label>
                            </div>

                            <!-- Option C -->
                            <div class="col-12 col-md-6">
                                <label class="card p-3 option-card">
                                    <div class="d-flex align-items-center">

                                        <input class="form-check-input me-3"
                                               type="radio"
                                               name="q${ind}"
                                               value="C" />

                                        <span class="badge bg-light text-dark border me-3">
                                            C
                                        </span>

                                        <span>${q.OptionC}</span>
                                    </div>
                                </label>
                            </div>

                            <!-- Option D -->
                            <div class="col-12 col-md-6">
                                <label class="card p-3 option-card">
                                    <div class="d-flex align-items-center">

                                        <input class="form-check-input me-3"
                                               type="radio"
                                               name="q${ind}"
                                               value="D" />

                                        <span class="badge bg-light text-dark border me-3">
                                            D
                                        </span>

                                        <span>${q.OptionD}</span>
                                    </div>
                                </label>
                            </div>

                        </div>
                    </div>
                `;

                $("#question-container").append(questionHTML)
            })
        }

    function formatTestTime(StartDateTime, EndDateTime) {

        const start = parseInt(StartDateTime.match(/\d+/)[0]);
        const end = parseInt(EndDateTime.match(/\d+/)[0]);

        const duration = (end - start) / 1000; // seconds

        return Math.floor(duration);
    }

    function renderTimer(totalSeconds, testID, userID) {

        var intervalID = setInterval(function () {

            const hours = Math.floor(totalSeconds / 3600);
            const minutes = Math.floor((totalSeconds % 3600) / 60);
            const seconds = totalSeconds % 60;

            const formatted =
                (hours > 0 ? (hours < 10 ? "0" : "") + hours + ":" : "") +
                (minutes < 10 ? "0" : "") + minutes + ":" +
                (seconds < 10 ? "0" : "") + seconds;

            $("#timerDisplay").text(formatted);

            totalSeconds--;

            if (totalSeconds < 0) {
                clearInterval(intervalID);
                $("#timerDisplay").text("Time Up!");

                Swal.fire({
                    title: "Auto Submit",
                    text: "Your test is auto submitted.",
                    icon: "success",
                    confirmButtonText: 'OK',
                    confirmButtonColor: "#3085d6",
                })
                    .then(() => {
                        submitTestData(testID, userID);
                    })
            }

        }, 1000);
    }

    function renderTestData(test) {

        $("#test-subject").text(test.SubjectName)
        $("#test-title").text(test.Title)
        $("#test-description").text(test.Description)

    }

    function examProctor() {
        //stop page realoading
        $(document).keydown(function (e) {

            if (e.key === "F5" || (e.ctrlKey && e.key === "r")) {
                e.preventDefault();
                alert("Reloading the page is not allowed during the test.");
            }

        });

        //disable back button
        history.pushState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };

        var tabSwitchCount = 0;
        //malpractice Identifictaion
        document.addEventListener("visibilitychange", function () {
            if (document.hidden) {
                tabSwitchCount++;
                console.log(tabSwitchCount);
                if (tabSwitchCount >= 3) {
                    Swal.fire({
                        title: "Maximum malpractice violations reached. Your test has been automatically submitted.",
                        icon: "error"
                    });
                    // submit test here
                    // $('#submitBtn').click();
                } else {

                    Swal.fire({
                        text: "Warning: Malpractice detected. This is violation " + tabSwitchCount + "/3. If you reach the maximum number of violations, your test will be automatically submitted.",
                        icon: "warning"
                    });
                }
            }
        });
    }

    function submitTestData(testID, userID) {

        answers = []

        const refQuestionCard = $(".questionCard")
        refQuestionCard.each(function () {
            const questionID = $(this)
                                    .find(".questionID")
                                    .val();
            const refSelectedOption = $(this)
                                    .find(".optionDiv")
                                    .find("input:checked")
                                    .val()

            answers.push({
                QuestionId: parseInt(questionID),
                AttemptedOption: refSelectedOption
            })
        })

        $.ajax({
            url: '@Url.Action("SubmitTest", "Test")',
            type: 'POST',
            data: {
                TestID: testID,
                StudentId: userID,
                Answers: answers
            },
            success: function (response) {
                console.log(response)
                if (response.Success) {
                    Swal.fire({
                        title: "Success!!",
                        text: "Test Submitted Successfully",
                        icon: "success",
                        showCancelButton: false,
                        confirmButtonText: 'OK',
                        confirmButtonColor: "#3085d6",
                    }).then(() => {
                        var baseUrl = '@Url.Action("Index", "Student", new { id = 0 })';
                        window.location.href = baseUrl.replace("0", userID);
                    })
                }
            },
            error: function (response) {
                console.log("Error: ", response)
            }
        })
    }

        $(document).ready(function () {

            const userID = localStorage.getItem("UserID");
            const testID = localStorage.getItem("selectedTestId");

            if (!testID) {
                Swal.fire({
                    icon: "error",
                    title: "Imposter",
                    text: "Unauthorized Access",
                }).then(() => {
                window.location.href = '@Url.Action("Index","Home")'
            });
            }



            //ajax call to fetch all questions
            $.ajax({
                url: '@Url.Action("StartTestJSONData", "Test")',
                type: 'GET',
                data: {
                    TestID: testID,
                    StudentId: userID
                },
                success: function (response) {
                    console.log(response)
                    if (response.Success) {

                        console.log("Response: ", response)
                        console.log("Questions: ", response.Questions)
                        renderTestData(response.Test)
                        renderQuestions(response.Questions)
                        examProctor()
                        const totalSeconds = formatTestTime(response.Test.StartDateTime, response.Test.EndDateTime);

                        //IF test duration is < 2hr then only it will be a timed test
                        // Student can submit using button or gets auto submit once timer stops
                        if (totalSeconds <= 7200) {
                            renderTimer(totalSeconds, testID, userID);
                            //Implement submit logic here!!
                        }
                        else {
                            console.log("Test duration is more than 2hr")
                            $("#timerDisplay").text("No Time Limit")
                            $("#timeRemainingHeader").addClass("d-none")
                            // Implement submit logic here!!
                        }
                    }
                    else {
                        Swal.fire({
                            title: "Error",
                            text: response.Message,
                            icon: "warning",
                            confirmButtonText: 'OK',
                            confirmButtonColor: "#3085d6",
                        })
                            .then(() => {

                                var baseUrl = '@Url.Action("Index", "Student", new { id = 0 })';
                                window.location.href = baseUrl.replace("0", userID);
                            })
                    }
                },
                error: function (response) {
                    console.log("Error response: ", response);
                }
            })

            $("#submitBtn").on("click", function () {
                Swal.fire({
                    title: "Are you sure?",
                    text: "Would you like to submit the test?",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: 'Yes',
                    confirmButtonColor: "#3085d6",
                    cancelButtonColor: "#d33",
                })
                    .then(() => {
                        submitTestData(testID, userID);
                        var baseUrl = '@Url.Action("Index", "Student", new { id = 0 })';
                        window.location.href = baseUrl.replace("0", userID);
                    })
            })



        })
</script>