@{
    ViewBag.Title = "Exam";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

@*@Html.Partial("_UnauthorizedAccess")*@

<div class="container-fluid bg-light min-vh-100 py-3">

    <!-- Top Banner -->
    <div class="container mb-3">
        <div class="alert border-start border-3 border-primary shadow-sm d-flex justify-content-between align-items-center flex-wrap py-2 px-3 small mb-0">
            <div>
                <strong>Exam Mode:</strong>
                <span class="text-primary">Timer running. Answers are auto-saved locally.</span>
            </div>
            <a href="#" class="text-danger text-decoration-none fw-semibold mt-1 mt-md-0">
                Quit Exam
            </a>
        </div>
    </div>

    <!-- Exam Card -->
    <div class="container">
        <div class="card shadow border-0 rounded-3">

            <!-- Header -->
            <div class="bg-dark text-white p-3 p-md-4">
                <div class="row align-items-center">

                    <div class="col-lg-8">
                        <span class="badge bg-primary px-2 py-1 mb-2 small">
                            COMPUTER SCIENCE
                        </span>

                        <h5 class="fw-bold mb-0">
                            Mid-Term SQL Assessment
                        </h5>
                    </div>

                    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                        <div class="d-inline-block bg-black rounded-3 px-3 py-2 text-center">
                            <div class="text-secondary text-uppercase small">
                                Time Remaining
                            </div>
                            <div class="text-warning fw-bold fs-5" id="timer">
                                4:39
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Questions Body -->
            <div class="card-body p-3 p-md-4" id="question-container">

                <!-- Question 1 -->



            </div>

            <!-- Submit Section -->
            <div class="card-footer bg-white py-3 px-3 px-md-4 text-end">
                <button class="btn btn-success btn-sm px-4">
                    Submit Exam
                </button>
            </div>

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.js" integrity="sha512-+k1pnlgt4F1H8L7t3z95o3/KO+o78INEcXTbnoJQ/F2VqDVhWoaiVml/OEHv9HsVgxUaVW+IbiZPUJQfF/YxZw==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

<script>
        //$("#question-container")

        const dummyResponse = {
            "test": {
                "testId": 1002,
                "title": "Math Unit Test",
                "description": "Basic arithmetic test",
                "targetClassId": 1,
                "className": "Grade 5",
                "subjectId": 10,
                "subjectName": "Mathematics",
                "startDateTime": "2026-03-28T09:30:00",
                "endDateTime": "2026-03-28T11:30:00",
                "testStatus": "Active",
                "attemptStatus": "Not Attempted",
                "scoreObtained": 0,
                "totalMarks": 10,
                "resultStatus": "Pending"
            },
            "questions": [
                {
                    "questionId": 1002,
                    "questionText": "What is 2 + 2?",
                    "optionA": "3",
                    "optionB": "4",
                    "optionC": "5",
                    "optionD": "6",
                    "marks": 5
                },
                {
                    "questionId": 1003,
                    "questionText": "What is 5 + 5?",
                    "optionA": "8",
                    "optionB": "9",
                    "optionC": "10",
                    "optionD": "11",
                    "marks": 5
                }
            ],
            "response": {
                "success": 1,
                "message": "Test started successfully."
            }
        }

        function renderQuestions(questions) {


            questions.map((q, ind) => {
                const questionHTML = `
                    <div class="mb-4">
                        <h6 class="mb-3">
                            ${ind+1}. ${q.QuestionText}
                        </h6>

                        <div class="row g-3">

                            <!-- Option A -->
                            <div class="col-12 col-md-6">
                                <label class="card p-3 option-card">
                                    <div class="d-flex align-items-center">

                                        <input class="form-check-input me-3"
                                               type="radio"
                                               name="q1"
                                               value="A" />

                                        <span class="badge bg-light text-dark border me-3">
                                            A
                                        </span>

                                        <span>${q.OptionA}</span>
                                    </div>
                                </label>
                            </div>

                            <!-- Option B -->
                            <div class="col-12 col-md-6">
                                <label class="card p-3 option-card">
                                    <div class="d-flex align-items-center">

                                        <input class="form-check-input me-3"
                                               type="radio"
                                               name="q1"
                                               value="B" />

                                        <span class="badge bg-light text-dark border me-3">
                                            B
                                        </span>

                                        <span>${q.OptionB}</span>
                                    </div>
                                </label>
                            </div>

                            <!-- Option C -->
                            <div class="col-12 col-md-6">
                                <label class="card p-3 option-card">
                                    <div class="d-flex align-items-center">

                                        <input class="form-check-input me-3"
                                               type="radio"
                                               name="q1"
                                               value="C" />

                                        <span class="badge bg-light text-dark border me-3">
                                            C
                                        </span>

                                        <span>${q.OptionC}</span>
                                    </div>
                                </label>
                            </div>

                            <!-- Option D -->
                            <div class="col-12 col-md-6">
                                <label class="card p-3 option-card">
                                    <div class="d-flex align-items-center">

                                        <input class="form-check-input me-3"
                                               type="radio"
                                               name="q1"
                                               value="D" />

                                        <span class="badge bg-light text-dark border me-3">
                                            D
                                        </span>

                                        <span>${q.OptionD}</span>
                                    </div>
                                </label>
                            </div>

                        </div>
                    </div>
                `;

                $("#question-container").append(questionHTML)
            })
        }

        $(document).ready(function () {

            const testID = localStorage.getItem("selectedTestId");
            const userID = localStorage.getItem("UserID");

            //ajax call to fetch all questions
            $.ajax({
                url: '@Url.Action("StartTestJSONData", "Test")',
                type: 'GET',
                data: {
                    TestID: testID,
                    StudentId: userID
                },
                success: function (response) {
                    if (response.Success) {

                        console.log("Response: ", response)
                        console.log("Questions: ",response.Questions)
                        renderQuestions(response.Questions)
                    }
                    //renderQuestions(response);
                },
                error: function (response) {
                    console.log("Error response: ", response);
                }
            })

            //renderQuestions(dummyResponse.questions)

        })
</script>